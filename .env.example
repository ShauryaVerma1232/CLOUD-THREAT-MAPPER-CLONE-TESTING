# ─────────────────────────────────────────────────────────────────────────────
# Threat Mapper — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=threatmapper
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=threatmapper

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme_neo4j_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=changeme_random_secret_key_min_32_chars
DEBUG=true
LOG_LEVEL=info

# ── AI Provider ───────────────────────────────────────────────────────────────
# RECOMMENDED: Google Gemini — free keys at https://aistudio.google.com/app/apikey
#
#   AI_PROVIDER=gemini       (Google Gemini — FREE)
#   AI_PROVIDER=anthropic    (Claude)
#   AI_PROVIDER=openai       (GPT-4o)
#   AI_PROVIDER=ollama       (local, no key needed)
#   AI_PROVIDER=none         (stub text, pipeline still runs)
#
AI_PROVIDER=none

# Gemini (recommended — free)
GEMINI_API_KEY=your-gemini-key-from-aistudio.google.com
GEMINI_MODEL=gemini-3-flash-preview

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional)
# OPENAI_API_KEY=sk-...

# Ollama (optional — local, no key)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_SCAN_PROFILE=threatmapper-readonly
AWS_SANDBOX_PROFILE=sandbox
AWS_CONFIG_DIR=/home/YOUR_WSL_USERNAME/.aws

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=4
