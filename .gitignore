# =====================
# Portfolio .gitignore
# Cloud Threat Mapper
# =====================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/

# --- Environment & Secrets ---
.env
*.pem
*.key
*.crt
credentials.json
*credentials*
service-account*.json

# --- Node.js ---
node_modules/
dist/
build/

# --- Docker ---
*.log
docker-data/
volumes/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Database & Data Volumes ---
*.db
*.sqlite3
neo4j_data/
postgres_data/
redis_data/

# --- Generated Scan Data ---
artifacts/

# --- Temporary Files ---
*.bak
*.tmp
*.temp

# --- Logs ---
logs/
*.log

# --- Testing ---
htmlcov/
.coverage
.pytest_cache/

# --- AWS CLI Installer ---
awscliv2.zip

# --- Personal/Workflow Files ---
claude.md
.claude/
.aider*
cleanup_*.ps1
cleanup_*.sh
debug_graph.py
generate_research_aspect.py
research_aspect.md
memory/sessions/

# --- PowerPoint & Presentations ---
ppt/
*.pptx
*.ppt

# --- Generated Paper Binaries (keep source .py scripts) ---
*.docx

# --- Research Images (keep in images/ folder) ---
# Images are tracked, but Zone.Identifier (Windows metadata) should not be
*:Zone.Identifier

# --- Research Paper Assets (track images, not generation scripts) ---
!docs/research/images/
docs/research/*.py
docs/research/*.md
docs/research/*.docx
